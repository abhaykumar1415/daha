{
  "name": "daha",
  "version": "1.0.0",
  "description": "Performance as Code for Next.js - Core Web Vitals and Lighthouse Audits CLI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "daha": "./dist/bin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --emitDeclarationOnly && node esbuild.config.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsx src/bin.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "esbuild": "^0.21.5",
    "execa": "^9.2.0",
    "fs-extra": "^11.2.0",
    "globby": "^14.0.1",
    "js-yaml": "^4.1.0",
    "junit-report-builder": "^3.2.1",
    "lighthouse": "^12.1.0",
    "lodash-es": "^4.17.21",
    "open": "^10.1.0",
    "ora": "^8.0.1",
    "playwright": "^1.45.0",
    "table": "^6.8.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.9",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
